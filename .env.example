# Скопируй в .env и заполни. .env в репозиторий не коммитится.

# --- Домены -------------------------------------------------------------
# Основной домен. dev: localhost, prod: example.com
DOMAIN=localhost

# Хосты сервисов. Если не заданы, выводятся из DOMAIN:
#   витрина  -> ${DOMAIN}            (корень основного домена)
#   админка  -> admin.${DOMAIN}
#   медиа    -> media.${DOMAIN}      (картинки товаров, отдаёт MinIO)
#   grafana  -> grafana.${DOMAIN}
# Переопредели любой из них, если нужна другая схема
# (например, SHOP_HOST=shop.example.com или ADMIN_HOST=panel.example.com).
SHOP_HOST=
ADMIN_HOST=
MEDIA_HOST=
GRAFANA_HOST=

# Почта для Let's Encrypt. Нужна только в проде (docker-compose.prod.yml).
ACME_EMAIL=

# --- Данные: локально или в облаке --------------------------------------
# Каждый backing-сервис задаётся через host/port/креды. Пустой HOST => дефолт
# на имя локального контейнера (db/cache/mq/storage), и `docker compose up`
# поднимает всё сам. Чтобы использовать managed-сервис (облачный PostgreSQL,
# Redis, RabbitMQ, S3) — впиши его HOST/PORT/креды/TLS ниже. Go-сервисы ходят
# к нему наружу через сеть edge.
#
# ВАЖНО: если сервис managed, локальный контейнер не нужен и не должен стартовать
# (иначе поднимется лишняя пустая БД). Отключай его явным списком сервисов, напр.:
#   docker compose up -d api bot worker web admin proxy   # без db/cache/mq/storage
# либо в проде вынеси набор поднимаемых сервисов в свой оверлей.

# ВНИМАНИЕ: комментарии — только на отдельной строке. docker compose НЕ срезает
# inline-комментарий после значения в .env (`HOST=   # foo` даст host = "# foo").

# --- PostgreSQL ---------------------------------------------------------
# Пусто => контейнер db. Для облака: host из панели провайдера.
POSTGRES_HOST=
POSTGRES_PORT=5432
POSTGRES_DB=tgshop
POSTGRES_USER=tgshop
POSTGRES_PASSWORD=change-me
# disable для локали; для облака обычно require / verify-full
POSTGRES_SSLMODE=disable

# --- Redis --------------------------------------------------------------
# Пусто => контейнер cache.
REDIS_HOST=
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=change-me
# redis без TLS; для облака с TLS ставь rediss
REDIS_SCHEME=redis

# --- RabbitMQ -----------------------------------------------------------
# Пусто => контейнер mq.
RABBITMQ_HOST=
RABBITMQ_PORT=5672
RABBITMQ_USER=tgshop
RABBITMQ_PASSWORD=change-me
# Пусто => vhost по умолчанию (/)
RABBITMQ_VHOST=
# amqp без TLS; для облака с TLS ставь amqps
RABBITMQ_SCHEME=amqp

# --- S3 / MinIO ---------------------------------------------------------
# Серверный endpoint. Пусто => локальный контейнер storage (http://storage:9000).
# Для облака укажи полный URL, напр. https://s3.yandexcloud.net или https://s3.amazonaws.com
S3_ENDPOINT=
S3_REGION=us-east-1
# MinIO и S3-совместимые требуют path-style; для настоящего AWS S3 ставь false
S3_USE_PATH_STYLE=true
# Креды используются и локальным MinIO (root user/pass), и облачным S3 (access/secret key)
MINIO_ROOT_USER=tgshop
MINIO_ROOT_PASSWORD=change-me-min-8-chars
MINIO_BUCKET=tgshop-media

# --- Telegram -----------------------------------------------------------
# Токен бота от @BotFather
BOT_TOKEN=
# Секрет в пути вебхука, чтобы посторонние не стучались в эндпоинт
BOT_WEBHOOK_SECRET=change-me

# --- Аутентификация -----------------------------------------------------
# Подпись JWT для персонала. Минимум 32 символа, значение проверяется при
# старте api: пустое, короткое или оставленное здесь значение-заглушка —
# отказ стартовать, а не тихая работа с общеизвестным ключом подписи.
# Сгенерировать: openssl rand -base64 48
JWT_SECRET=

# --- Grafana ------------------------------------------------------------
GRAFANA_ADMIN_PASSWORD=change-me
# Только для прод-оверлея: basic-auth перед Grafana.
# Сгенерировать: htpasswd -nb admin '<пароль>' | sed -e 's/\$/\$\$/g'
GRAFANA_BASIC_AUTH=

# --- Приложение ---------------------------------------------------------
LOG_LEVEL=info
